{
  "name": "@nullius/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nullius": "dist-publish/nullius.cjs"
  },
  "files": [
    "dist-publish"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "bundle:action": "node scripts/bundle-action.mjs",
    "bundle:publish": "node scripts/bundle-publish.mjs",
    "prepublishOnly": "node scripts/bundle-publish.mjs"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@nullius/core": "workspace:*",
    "@nullius/server": "workspace:*",
    "esbuild": "^0.28.1",
    "vitest": "^2.1.8"
  }
}
