{
  "suite": "numeric-grounding",
  "cases": [
    {
      "name": "significant numbers skip integers and years",
      "input": {
        "operation": "significantNumbers",
        "text": "500 samples, slope 2.03, error 1.2e-3, rate 95.4%, year 2024"
      },
      "expect": {
        "values": ["2.03", "1.2e-3", "95.4%"]
      }
    },
    {
      "name": "rounded artifact value grounds body number",
      "input": {
        "operation": "groundingReport",
        "body": "# Results\nThe slope is 2.03.",
        "artifactTexts": ["slope,2.0347"]
      },
      "expect": {
        "ungroundedNumbers": []
      }
    },
    {
      "name": "percent can be grounded by fraction",
      "input": {
        "operation": "groundingReport",
        "body": "# Results\nAccuracy reached 95.4%.",
        "artifactTexts": ["accuracy,0.954"]
      },
      "expect": {
        "ungroundedNumbers": []
      }
    },
    {
      "name": "substring collision does not ground",
      "input": {
        "operation": "groundingReport",
        "body": "# Results\nThe effect size was 0.87.",
        "artifactTexts": ["metric,value\nother,10.873"]
      },
      "expect": {
        "ungroundedNumbers": ["0.87"]
      }
    },
    {
      "name": "abstract and discussion numbers are checked",
      "input": {
        "operation": "groundingReport",
        "body": "# Abstract\nAccuracy reached 99.1%.\n# Methods\nStandard pipeline.\n# Discussion\nThe slope of 7.77 is striking.",
        "artifactTexts": ["accuracy,0.5\nslope,2.0"]
      },
      "expect": {
        "ungroundedNumbers": ["99.1%", "7.77"]
      }
    },
    {
      "name": "years are not integer targets",
      "input": {
        "operation": "significantIntegers",
        "text": "Collected in 2024 and revised in 1999."
      },
      "expect": {
        "values": []
      }
    }
  ]
}

