{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nullius",
  "version": "0.1.0",
  "identifier": "com.nullius.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nullius",
        "width": 1320,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
